{
  "name": "text-master",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/start-text-master-desktop.mjs",
    "dev:web": "cd apps/web && vite --host 127.0.0.1 --port 5173",
    "dev:api": "cd apps/api && node src/main.mjs",
    "desktop": "node scripts/start-text-master-desktop.mjs",
    "typecheck": "npm run typecheck:web && npm run typecheck:api",
    "typecheck:web": "cd apps/web && vue-tsc --noEmit",
    "typecheck:api": "cd apps/api && npm run typecheck",
    "build": "npm run build:web && npm run build:api",
    "build:web": "cd apps/web && vite build",
    "build:api": "cd apps/api && npm run build",
    "audit:text-master:api": "node scripts/audit-text-master-api.mjs",
    "audit:text-master:provider": "node scripts/audit-text-master-provider-config.mjs",
    "audit:text-master:storage": "node scripts/audit-text-master-storage.mjs",
    "audit:text-master:visual": "node scripts/audit-text-master-visual.mjs",
    "audit:text-master:mvp": "node scripts/audit-text-master-mvp.mjs"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "playwright": "^1.60.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vue-tsc": "^2.1.0"
  }
}
